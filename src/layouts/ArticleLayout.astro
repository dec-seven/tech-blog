---
import TagList from "../components/TagList.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { formatDate } from "../lib/content";
import BaseLayout from "./BaseLayout.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  kind: string;
  headings?: Heading[];
}

const { title, description, pubDate, updatedDate, tags = [], kind, headings = [] } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const hasToc = tocHeadings.length > 0;
---

<BaseLayout title={title} description={description}>
  <div class:list={["article-frame", hasToc && "article-frame--with-toc"]}>
    <article class="article-shell" data-pagefind-body>
      <header class="article-header">
        <p class="eyebrow">{kind}</p>
        <h1>{title}</h1>
        <p class="article-description">{description}</p>
        <div class="article-meta">
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          {
            updatedDate && (
              <span>
                更新于 <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
              </span>
            )
          }
        </div>
        <TagList tags={tags} />
      </header>
      {hasToc && <TableOfContents headings={tocHeadings} class="article-toc--inline" />}
      <div class="prose">
        <slot />
      </div>
    </article>
    {hasToc && <TableOfContents headings={tocHeadings} class="article-toc--side" />}
  </div>
</BaseLayout>
