---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const siteTitle = "DecSeven";
const defaultDescription = "DecSeven 的个人技术博客：记录工程实践、系统设计、工具链与持续学习。";
const { title = siteTitle, description = defaultDescription } = Astro.props;
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const pathname = Astro.url.pathname;
const ogImage = new URL("/og.png", Astro.site ?? Astro.url).toString();

const navItems = [
  { href: "/posts/", label: "文章" },
  { href: "/notes/", label: "笔记" },
  { href: "/docs/", label: "文档" },
  { href: "/search/", label: "搜索" },
  { href: "/about/", label: "关于" }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="DecSeven RSS" href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">跳到内容</a>
    <header class="site-header" data-pagefind-ignore>
      <a class="brand" href="/" aria-label="DecSeven 首页">
        <img src="/favicon.svg" width="32" height="32" alt="" />
        <span>DecSeven</span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              aria-current={pathname.startsWith(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer" data-pagefind-ignore>
      <p>© {new Date().getFullYear()} DecSeven</p>
      <a href="/rss.xml">RSS</a>
    </footer>
    <script is:inline>
      (() => {
        const languageNames = {
          bash: "bash",
          sh: "shell",
          shell: "shell",
          text: "text",
          plaintext: "text",
          yaml: "yaml",
          yml: "yaml",
          ini: "ini",
          js: "js",
          ts: "ts",
          json: "json"
        };

        const getLanguage = (pre, code) => {
          const dataLanguage = pre.dataset.language;
          if (dataLanguage) return languageNames[dataLanguage] ?? dataLanguage;

          const languageClass = [...code.classList].find((className) =>
            className.startsWith("language-")
          );
          const key = languageClass?.replace("language-", "") ?? "";
          return languageNames[key] ?? key ?? "code";
        };

        const enhanceCodeBlocks = () => {
          document.querySelectorAll(".prose pre").forEach((pre) => {
            if (pre.parentElement?.classList.contains("code-shell")) return;

            const code = pre.querySelector("code");
            if (!code) return;

            const wrapper = document.createElement("div");
            wrapper.className = "code-shell";

            const bar = document.createElement("div");
            bar.className = "code-shell__bar";

            const label = document.createElement("span");
            label.className = "code-shell__lang";
            label.textContent = getLanguage(pre, code);

            const button = document.createElement("button");
            button.className = "code-shell__copy";
            button.type = "button";
            button.textContent = "复制";

            button.addEventListener("click", async () => {
              const text = code.innerText;
              try {
                await navigator.clipboard.writeText(text);
                button.textContent = "已复制";
              } catch {
                button.textContent = "手动复制";
              }
              window.setTimeout(() => {
                button.textContent = "复制";
              }, 1600);
            });

            bar.append(label, button);
            pre.parentNode?.insertBefore(wrapper, pre);
            wrapper.append(bar, pre);
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", enhanceCodeBlocks);
        } else {
          enhanceCodeBlocks();
        }
      })();
    </script>
  </body>
</html>
