---
import { homeProfile } from "../data/home";

interface Stats {
  posts: number;
  notes: number;
  docs: number;
}

interface Props {
  stats: Stats;
}

const { stats } = Astro.props;
---

<section class="profile-hero section-band" aria-labelledby="profile-title">
  <div class="profile-card">
    <div class="profile-card__header">
      <img class="profile-card__avatar" src={homeProfile.avatar} width="88" height="88" alt="" />
      <div>
        <p class="eyebrow">个人知识库</p>
        <h1 id="profile-title">{homeProfile.name}</h1>
        <p class="profile-card__role">{homeProfile.role}</p>
      </div>
    </div>

    <p class="profile-card__bio">{homeProfile.bio}</p>

    <div class="profile-card__links" aria-label="主要入口">
      {
        homeProfile.primaryLinks.map((link) => (
          <a href={link.href}>
            <span>{link.label}</span>
            <small>{link.description}</small>
          </a>
        ))
      }
    </div>

    <div class="profile-card__footer">
      <ul class="profile-card__social" aria-label="相关链接">
        {
          homeProfile.socialLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
      <span>{homeProfile.location}</span>
    </div>
  </div>

  <aside class="profile-side" aria-label="内容概览">
    <div class="profile-side__intro">
      <p class="eyebrow">当前关注</p>
      <h2>一边被卷，一边折腾</h2>
      <p>聊技术，也聊真实踩坑。把复杂的东西，尽量讲简单一点。</p>
    </div>
    <dl class="stat-grid stat-grid--stacked" aria-label="内容统计">
      <div>
        <dt>文章</dt>
        <dd>{stats.posts}</dd>
      </div>
      <div>
        <dt>笔记</dt>
        <dd>{stats.notes}</dd>
      </div>
      <div>
        <dt>文档</dt>
        <dd>{stats.docs}</dd>
      </div>
    </dl>
  </aside>
</section>
