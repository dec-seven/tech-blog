---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="关于" description="关于这个技术博客。">
  <section class="article-shell" data-pagefind-body>
    <header class="article-header">
      <p class="eyebrow">About</p>
      <h1>关于</h1>
      <p class="article-description">
        这里用于沉淀技术文章、项目经验、学习笔记和可分享文档。
      </p>
    </header>
    <div class="prose">
      <p>
        你可以把这里改成个人介绍、写作方向、联系方式，或者放上常用项目链接。
      </p>
    </div>
  </section>
</BaseLayout>
