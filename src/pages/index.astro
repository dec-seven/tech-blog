---
import { getCollection } from "astro:content";
import ContentCard from "../components/ContentCard.astro";
import ProfilePanel from "../components/ProfilePanel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { collectionMeta, entryHref, uniqueTags, type ContentKind } from "../lib/content";

const [posts, notes, docs] = await Promise.all([
  getCollection("posts", ({ data }) => !data.draft),
  getCollection("notes", ({ data }) => !data.draft),
  getCollection("docs", ({ data }) => !data.draft)
]);

const allItems = [
  ...posts.map((entry) => ({ kind: "posts" as ContentKind, entry })),
  ...notes.map((entry) => ({ kind: "notes" as ContentKind, entry })),
  ...docs.map((entry) => ({ kind: "docs" as ContentKind, entry }))
].sort((a, b) => b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf());

const latestItems = allItems.slice(0, 8);
const tags = uniqueTags([...posts, ...notes, ...docs]).slice(0, 18);
---

<BaseLayout>
  <ProfilePanel stats={{ posts: posts.length, notes: notes.length, docs: docs.length }} />

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">最新</p>
        <h2>最新内容</h2>
      </div>
      <a class="text-link" href="/search/">搜索全部</a>
    </div>
    <div class="content-grid">
      {
        latestItems.map(({ kind, entry }) => (
          <ContentCard
            href={entryHref(kind, entry)}
            title={entry.data.title}
            description={entry.data.description}
            pubDate={entry.data.pubDate}
            tags={entry.data.tags}
            kind={collectionMeta[kind].label}
          />
        ))
      }
    </div>
  </section>

  <section class="section section-split">
    <div>
      <p class="eyebrow">分类</p>
      <h2>内容分类</h2>
    </div>
    <div class="collection-links">
      <a href="/posts/">
        <span>文章</span>
        <strong>{posts.length}</strong>
      </a>
      <a href="/notes/">
        <span>笔记</span>
        <strong>{notes.length}</strong>
      </a>
      <a href="/docs/">
        <span>文档</span>
        <strong>{docs.length}</strong>
      </a>
    </div>
  </section>

  {
    tags.length > 0 && (
      <section class="section">
        <div class="section-heading">
          <div>
            <p class="eyebrow">标签</p>
            <h2>标签</h2>
          </div>
        </div>
        <ul class="tag-cloud" aria-label="标签">
          {tags.map((tag) => (
            <li>
              <a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
